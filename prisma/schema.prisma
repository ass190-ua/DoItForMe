// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rating    Float    @default(0)
  is_runner Boolean  @default(false)

  tasksCreated  Task[]  @relation("CreatorRelation")
  tasksAssigned Task[]  @relation("RunnerRelation")
  offers        Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskCategory {
  COLA
  COMPRA
  RECOGIDA
  OTROS
}

enum TaskStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

model Task {
  id             Int          @id @default(autoincrement())
  titulo         String
  descripcion    String
  categoria      TaskCategory
  estado         TaskStatus   @default(OPEN)
  precio_inicial Float
  precio_final   Float?
  lat            Float?
  lng            Float?

  creator_id     Int
  creator        User         @relation("CreatorRelation", fields: [creator_id], references: [id])

  runner_id      Int?
  runner         User?        @relation("RunnerRelation", fields: [runner_id], references: [id])

  offers         Offer[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Offer {
  id               Int         @id @default(autoincrement())
  
  task_id          Int
  task             Task        @relation(fields: [task_id], references: [id])

  runner_id        Int
  runner           User        @relation(fields: [runner_id], references: [id])

  precio_propuesto Float
  mensaje          String?
  estado           OfferStatus @default(PENDING)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}
